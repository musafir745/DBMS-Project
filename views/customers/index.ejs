<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <h3 class="mb-0">Customers</h3>
  <a href="/customers/new" class="btn btn-dark add-btn">Add Customer</a>
</div>

<% if (customers.length) { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Bookings</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (let customer of customers) { %>
          <tr>
            <td><%= customer.customer_id %></td>
            <td><%= customer.name %></td>
            <td><%= customer.email || "Not provided" %></td>
            <td><%= customer.phone || "Not provided" %></td>
            <td><%= customer.booking_count %></td>
            <td>
              <div class="table-actions">
                <a href="/customers/<%= customer.customer_id %>" class="btn btn-sm btn-outline-dark">View</a>
                <a href="/customers/<%= customer.customer_id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form action="/customers/<%= customer.customer_id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete this customer and related bookings?')">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">
    <p class="mb-3">No customers found.</p>
    <a href="/customers/new" class="btn btn-dark add-btn">Add Customer</a>
  </div>
<% } %>
