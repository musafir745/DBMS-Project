<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <div>
    <h3 class="mb-1">Manage Users</h3>
    <p class="text-muted mb-0">Customer accounts and administrator accounts.</p>
  </div>
</div>

<% if (users.length) { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>ID</th>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Role</th>
          <th>Bookings</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (let user of users) { %>
          <tr>
            <td><%= user.user_id %></td>
            <td><%= user.name %></td>
            <td><%= user.email %></td>
            <td><%= user.phone || "Not provided" %></td>
            <td><span class="status-pill <%= user.role === 'admin' ? 'status-Completed' : 'status-Confirmed' %>"><%= user.role %></span></td>
            <td><%= user.booking_count %></td>
            <td>
              <div class="table-actions">
                <a href="/customers/<%= user.user_id %>" class="btn btn-sm btn-outline-dark">View</a>
                <a href="/customers/<%= user.user_id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <% if (!currUser || currUser.id !== user.user_id) { %>
                  <form action="/customers/<%= user.user_id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete this user and their related bookings?')">
                    <button class="btn btn-sm btn-outline-danger">Delete</button>
                  </form>
                <% } %>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">No users found.</div>
<% } %>
