<% layout('./layouts/boilerplate') -%>

<div class="detail-section">
  <div class="management-header">
    <div>
      <h3 class="mb-1"><%= user.name %></h3>
      <p class="text-muted mb-0">User ID: <%= user.user_id %> | Role: <%= user.role %></p>
    </div>
    <div class="table-actions">
      <a href="/customers/<%= user.user_id %>/edit" class="btn btn-dark edit-btn">Edit</a>
      <% if (user.role === "customer") { %>
        <a href="/bookings/new?customer_id=<%= user.user_id %>" class="btn btn-outline-success">Add Booking</a>
      <% } %>
      <% if (!currUser || currUser.id !== user.user_id) { %>
        <form action="/customers/<%= user.user_id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete this user and related bookings?')">
          <button class="btn btn-outline-danger">Delete</button>
        </form>
      <% } %>
    </div>
  </div>

  <div class="card">
    <div class="card-body p-3">
      <p><b>Email:</b> <%= user.email %></p>
      <p class="mb-0"><b>Phone:</b> <%= user.phone || "Not provided" %></p>
    </div>
  </div>
</div>

<div class="detail-section">
  <div class="management-header">
    <h4 class="mb-0">Booking Records</h4>
  </div>

  <% if (bookings.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Hotel</th>
            <th>Room</th>
            <th>Check In</th>
            <th>Check Out</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% for (let booking of bookings) { %>
            <tr>
              <td><%= booking.booking_id %></td>
              <td><%= booking.hotel_name %></td>
              <td><%= booking.room_type %></td>
              <td><%= booking.check_in_date %></td>
              <td><%= booking.check_out_date %></td>
              <td><span class="status-pill status-<%= booking.status %>"><%= booking.status %></span></td>
              <td>
                <div class="table-actions">
                  <a href="/bookings/<%= booking.booking_id %>" class="btn btn-sm btn-outline-dark">View</a>
                  <a href="/bookings/<%= booking.booking_id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">No booking records found for this user.</div>
  <% } %>
</div>
