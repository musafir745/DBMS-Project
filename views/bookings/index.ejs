<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <h3 class="mb-0">Manage Bookings</h3>
  <a href="/bookings/new" class="btn btn-dark add-btn">Add Booking</a>
</div>

<% if (bookings.length) { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>ID</th>
          <th>Customer</th>
          <th>Hotel</th>
          <th>Room</th>
          <th>Check In</th>
          <th>Check Out</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (let booking of bookings) { %>
          <tr>
            <td><%= booking.booking_id %></td>
            <td><%= booking.customer_name %></td>
            <td><%= booking.hotel_name %></td>
            <td><%= booking.room_type %></td>
            <td><%= booking.check_in_date %></td>
            <td><%= booking.check_out_date %></td>
            <td><span class="status-pill status-<%= booking.status %>"><%= booking.status %></span></td>
            <td>
              <div class="table-actions">
                <a href="/bookings/<%= booking.booking_id %>" class="btn btn-sm btn-outline-dark">View</a>
                <a href="/bookings/<%= booking.booking_id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <% if (booking.status !== "Cancelled") { %>
                  <form action="/bookings/<%= booking.booking_id %>/cancel?_method=PUT" method="post">
                    <button class="btn btn-sm btn-outline-warning">Cancel</button>
                  </form>
                <% } %>
                <form action="/bookings/<%= booking.booking_id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete this booking?')">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">
    <p class="mb-3">No bookings found.</p>
    <a href="/bookings/new" class="btn btn-dark add-btn">Add Booking</a>
  </div>
<% } %>
