<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <h3 class="mb-0">Manage Rooms</h3>
  <a href="/rooms/new" class="btn btn-dark add-btn">Add Room</a>
</div>

<% if (rooms.length) { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>ID</th>
          <th>Hotel</th>
          <th>Room Type</th>
          <th>Capacity</th>
          <th>Price</th>
          <th>Availability</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (let room of rooms) { %>
          <tr>
            <td><%= room.room_id %></td>
            <td>
              <a href="/listings/<%= room.hotel_id %>" class="text-dark"><%= room.hotel_name %></a>
              <div class="text-muted small"><%= room.hotel_location %></div>
            </td>
            <td><%= room.room_type %></td>
            <td><%= room.capacity %></td>
            <td>৳<%= Number(room.price).toLocaleString("en-BD") %></td>
            <td><%= room.availability %></td>
            <td>
              <div class="table-actions">
                <a href="/rooms/<%= room.room_id %>" class="btn btn-sm btn-outline-dark">View</a>
                <a href="/rooms/<%= room.room_id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form action="/rooms/<%= room.room_id %>?_method=DELETE" method="post" onsubmit="return confirm('Delete this room and its related bookings?')">
                  <button class="btn btn-sm btn-outline-danger">Delete</button>
                </form>
              </div>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">
    <p class="mb-3">No rooms found.</p>
    <a href="/rooms/new" class="btn btn-dark add-btn">Add Room</a>
  </div>
<% } %>
