<style>
  .search-btn {
    background: #fe424d;
    color: white;
    border-radius: 25px;
    border: 1px solid #fe424d;
    font-size: 0.9rem;
  }

  .search-btn:hover {
    background: #fe424d;
    color: white;
    border: 1px solid #fe424d;
  }

  .search-inp {
    font-size: 0.9rem;
    border-radius: 25px;
    padding: 0.5rem 1.5rem;
  }

  .navhover:hover {
    background: #efeeee;
    border-radius: 25px;
  }

  .addbnb {
    background: #dbdbdb;
    border-radius: 20px;
  }
</style>

<nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom sticky-top">
  <div class="container-fluid">
    <a class="navbar-brand" href="/listings"><i class="fa-regular fa-compass"></i></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Hotels</a>

        <% if (currUser && currUser.role === "customer") { %>
          <a class="nav-link" href="/customer/dashboard">My Dashboard</a>
          <a class="nav-link" href="/customer/bookings">My Bookings</a>
          <a class="nav-link" href="/customer/profile">My Profile</a>
        <% } %>

        <% if (currUser && currUser.role === "admin") { %>
          <a class="nav-link" href="/admin/dashboard">Admin Dashboard</a>
          <a class="nav-link" href="/listings">Manage Listings</a>
          <a class="nav-link" href="/rooms">Manage Rooms</a>
          <a class="nav-link" href="/bookings">Manage Bookings</a>
          <a class="nav-link" href="/customers">Manage Users</a>
        <% } %>
      </div>

      <div class="search-box navbar-nav ms-auto">
        <form class="d-flex" role="search" action="/listings" method="get">
          <input class="form-control me-2 search-inp" name="q" type="search" placeholder="Search destinations" aria-label="Search">
          <button class="btn search-btn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>

      <div class="navbar-nav ms-auto align-items-lg-center">
        <% if (!currUser) { %>
          <a class="nav-link navhover" href="/auth/register">Register</a>
          <a class="nav-link navhover" href="/auth/login">Customer Login</a>
          <a class="nav-link navhover addbnb" href="/admin/login">Admin Login</a>
        <% } else if (currUser.role === "customer") { %>
          <form action="/auth/logout" method="post">
            <button class="btn nav-link navhover border-0 bg-transparent">Logout</button>
          </form>
        <% } else { %>
          <a class="nav-link navhover addbnb" href="/listings/new">Add Hotel</a>
          <form action="/admin/logout" method="post">
            <button class="btn nav-link navhover border-0 bg-transparent">Admin Logout</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</nav>
