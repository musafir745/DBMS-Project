<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <div>
    <h3 class="mb-1">Admin Dashboard</h3>
    <p class="text-muted mb-0">Overview of the WanderLust booking system.</p>
  </div>
</div>

<div class="dashboard-grid">
  <a href="/listings" class="stat-card stat-link"><span>Listings</span><strong><%= stats.hotels %></strong></a>
  <a href="/rooms" class="stat-card stat-link"><span>Rooms</span><strong><%= stats.rooms %></strong></a>
  <a href="/customers" class="stat-card stat-link"><span>Customers</span><strong><%= stats.customers %></strong></a>
  <a href="/bookings" class="stat-card stat-link"><span>Total Bookings</span><strong><%= stats.bookings %></strong></a>
  <a href="/bookings" class="stat-card stat-link"><span>Pending Requests</span><strong><%= stats.pending %></strong></a>
</div>

<div class="detail-section">
  <div class="management-header">
    <h4 class="mb-0">Recent Bookings</h4>
    <a href="/bookings" class="btn btn-outline-dark">Manage Bookings</a>
  </div>

  <% if (recentBookings.length) { %>
    <div class="table-responsive">
      <table class="table table-hover align-middle">
        <thead>
          <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Hotel</th>
            <th>Room</th>
            <th>Check In</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% for (let booking of recentBookings) { %>
            <tr>
              <td><%= booking.booking_id %></td>
              <td><%= booking.customer_name %></td>
              <td><%= booking.hotel_name %></td>
              <td><%= booking.room_type %></td>
              <td><%= booking.check_in_date %></td>
              <td><span class="status-pill status-<%= booking.status %>"><%= booking.status %></span></td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="empty-state">No bookings found.</div>
  <% } %>
</div>
