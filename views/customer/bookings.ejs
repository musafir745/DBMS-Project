<% layout('./layouts/boilerplate') -%>

<div class="management-header">
  <div>
    <h3 class="mb-1">My Bookings</h3>
    <p class="text-muted mb-0">Only booking records created from your account are shown here.</p>
  </div>
  <a href="/customer/bookings/new" class="btn btn-dark add-btn">Create Booking</a>
</div>

<% if (bookings.length) { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Hotel</th>
          <th>Room</th>
          <th>Check In</th>
          <th>Check Out</th>
          <th>Status</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% for (let booking of bookings) { %>
          <tr>
            <td><a href="/listings/<%= booking.hotel_id %>" class="text-dark"><%= booking.hotel_name %></a></td>
            <td><%= booking.room_type %></td>
            <td><%= booking.check_in_date %></td>
            <td><%= booking.check_out_date %></td>
            <td><span class="status-pill status-<%= booking.status %>"><%= booking.status %></span></td>
            <td>
              <% if (booking.status === "Pending" || booking.status === "Confirmed") { %>
                <form action="/customer/bookings/<%= booking.booking_id %>/cancel?_method=PUT" method="post">
                  <button class="btn btn-sm btn-outline-warning">Cancel</button>
                </form>
              <% } else { %>
                <span class="text-muted small">No action available</span>
              <% } %>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } else { %>
  <div class="empty-state">
    <p class="mb-3">You have no booking records.</p>
    <a href="/listings" class="btn btn-dark add-btn">Browse Hotels</a>
  </div>
<% } %>
